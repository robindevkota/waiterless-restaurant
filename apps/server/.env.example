# ── Server ─────────────────────────────────────────────────────────────────────
PORT=5000
NODE_ENV=development

# ── Database ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017/waiterless

# ── Auth ───────────────────────────────────────────────────────────────────────
JWT_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
# Encrypts per-tenant AI keys at rest — keep stable across JWT rotations
SECRETBOX_KEY=change_me_to_a_third_random_string
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
JWT_GUEST_EXPIRES=2h

# ── CORS ────────────────────────────────────────────────────────────────────────
CLIENT_URL=http://localhost:3000

# ── Cloudinary (menu item images, logos) ───────────────────────────────────────
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ── Email (staff invites) ──────────────────────────────────────────────────────
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@waiterless.app

# ── AI analyst (env fallback; per-restaurant keys in Settings take priority) ──
GEMINI_API_KEY=
GROQ_API_KEY=
